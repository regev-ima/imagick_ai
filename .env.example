# ═══════════════════════════════════════════════════════════════════════════
# Imagick.ai — environment variable reference
# ═══════════════════════════════════════════════════════════════════════════
#
# This file is the source of truth for every config value the app needs.
# Copy it to `.env` for local development (Vite reads only VITE_* vars from
# there) and fill in real values. Backend secrets do NOT belong in `.env` —
# they are set in Supabase Edge Function secrets:
#   https://supabase.com/dashboard/project/<id>/settings/functions
#
# Sections:
#   1. Frontend (Vite, embedded in bundle — public)
#   2. Supabase Edge Function Secrets (private — set via dashboard)
#      a. Auto-injected by Supabase
#      b. Domain & branding
#      c. Imagick AI Worker (image processing)
#      d. Email (Resend)
#      e. WhatsApp (Green API)
#      f. Telegram (alerts)
#      g. Sentry (error tracking)
#      h. PayPal (billing)
#      i. Azure (face detection)


# ───────────────────────────────────────────────────────────────────────────
# 1. Frontend (public — embedded in bundle)
# ───────────────────────────────────────────────────────────────────────────

# Supabase project the frontend talks to
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Sentry DSN — DSN is public-safe by design
# VITE_SENTRY_DSN="https://xxxxx@oXXXXX.ingest.us.sentry.io/XXXXX"

# Optional: app version, used for Sentry release tagging
# VITE_APP_VERSION="1.0.0"


# ═══════════════════════════════════════════════════════════════════════════
# 2. Supabase Edge Function Secrets (set via Supabase dashboard, NOT in .env)
# ═══════════════════════════════════════════════════════════════════════════

# ─── 2a. Auto-injected by Supabase (do not set manually) ───────────────────
# SUPABASE_URL                — automatically available in every function
# SUPABASE_ANON_KEY           — automatically available
# SUPABASE_SERVICE_ROLE_KEY   — automatically available


# ─── 2b. Domain & branding ─────────────────────────────────────────────────

# Public app URL used in email links, OAuth redirects, invoice URLs.
# Falls back to https://app.imagick.ai if not set.
# STUDIO_URL=https://app.imagick.ai


# ─── 2c. Imagick AI Worker (image processing, training, culling) ───────────

# Cloudflare Worker that runs the AI editing/training/grouping API.
# (Currently hardcoded in edge functions to https://imagick-api-endpoint.rx8rq49b5c.workers.dev
# — recommended TODO: move into a secret IMAGICK_API_ENDPOINT.)
# IMAGICK_API_USERNAME=your-basic-auth-user
# IMAGICK_API_PASSWORD=your-basic-auth-password


# ─── 2d. Email (Resend) ────────────────────────────────────────────────────

# Resend API key. Required for ALL outgoing email. If unset, emails are
# logged with metadata.dev_mode = true and not actually sent.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── 2e. WhatsApp (Green API — admin notifications on signup, gallery ready) ─

# Green API instance for sending WhatsApp messages to the admin number.
# GREEN_API_INSTANCE_ID=your-instance-id
# GREEN_API_TOKEN=your-api-token
# GREEN_API_CHAT_ID=your-chat-id   # admin number, e.g. 972501234567@c.us


# ─── 2f. Telegram (Sentry → Telegram alert relay) ─────────────────────────

# Used by the sentry-telegram-relay edge function to forward Sentry alerts.
# Bot token from @BotFather, chat ID from @userinfobot.
# TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
# TELEGRAM_CHAT_ID=987654321
# Optional shared secret for Sentry HMAC verification:
# SENTRY_WEBHOOK_SECRET=optional-shared-secret


# ─── 2g. Sentry (backend error tracking) ──────────────────────────────────

# DSN for the Node.js/Deno project that receives backend errors. If unset,
# the code falls back to using SENTRY_DSN (the frontend project DSN) so a
# single project can capture both. Recommended: separate projects.
# SENTRY_DSN=https://xxxxx@oXXXXX.ingest.us.sentry.io/XXXXX
# SENTRY_DSN_BACKEND=https://xxxxx@oXXXXX.ingest.us.sentry.io/XXXXX
# SENTRY_ENVIRONMENT=production


# ─── 2h. PayPal (billing, subscriptions, addons) ──────────────────────────

# Sandbox credentials — used when the platform is in sandbox mode
# PAYPAL_SANDBOX_CLIENT_ID=your-sandbox-client-id
# PAYPAL_SANDBOX_CLIENT_SECRET=your-sandbox-client-secret
# PAYPAL_SANDBOX_WEBHOOK_ID=your-sandbox-webhook-id

# Live credentials — used in production
# PAYPAL_LIVE_CLIENT_ID=your-live-client-id
# PAYPAL_LIVE_CLIENT_SECRET=your-live-client-secret
# PAYPAL_LIVE_WEBHOOK_ID=your-live-webhook-id


# ─── 2i. Azure Face API (face detection / clustering inside galleries) ────

# Azure Cognitive Services key for the Face API. Used by the face search
# feature on client galleries.
# AZURE_FACE_API_KEY=your-azure-face-api-key
